# OpenClaw Twins - Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Database
*.db
*.sqlite
*.sqlite3

# Data directories
data/
!data/.gitkeep
metrics/daily/
metrics/reports/
metrics/proposals/
!metrics/proposals/.gitkeep
backups/
*.tar.gz

# Logs
*.log
logs/

# Runtime files
.pids
*.pid

# Coverage
.coverage
htmlcov/
.pytest_cache/

# Docker
.dockerignore

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
build/
dist/
